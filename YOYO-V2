# =====================================================
# 🔐 Passwörter
# =====================================================
USER_PASSWORD = "oyysouth"
SILENT_USER_PASSWORD = "silentlogin"
ADMIN_PASSWORD = "sebaforceo"

# =====================================================
# 🌍 Länder-Konfiguration
# =====================================================
COUNTRY_CONFIG = {
    "DE": {"name": "Deutschland", "currency": "€", "features": {"pipeline": True, "advanced_pricing": True}},
    "AT": {"name": "Österreich", "currency": "€", "features": {"pipeline": True, "advanced_pricing": True}},
    "CH": {"name": "Schweiz", "currency": "CHF", "features": {"pipeline": False, "advanced_pricing": True}},
    "BE": {"name": "Belgien", "currency": "€", "features": {"pipeline": False, "advanced_pricing": True}},
    "LU": {"name": "Luxemburg", "currency": "€", "features": {"pipeline": False, "advanced_pricing": True}},
    "NL": {"name": "Niederlande", "currency": "€", "features": {"pipeline": False, "advanced_pricing": True}},
    "UK": {"name": "England", "currency": "£", "features": {"pipeline": False, "advanced_pricing": True}},
    "IE": {"name": "Irland", "currency": "€", "features": {"pipeline": False, "advanced_pricing": True}},
    "SC": {"name": "Schottland", "currency": "£", "features": {"pipeline": False, "advanced_pricing": True}},
    "FI": {"name": "Finnland", "currency": "€", "features": {"pipeline": False, "advanced_pricing": True}},
    "SE": {"name": "Schweden", "currency": "SEK", "features": {"pipeline": False, "advanced_pricing": True}},
    "DK": {"name": "Dänemark", "currency": "DKK", "features": {"pipeline": False, "advanced_pricing": True}},
